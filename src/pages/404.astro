---
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';
import CodeBlock from '~/components/ui/CodeBlock.astro';
import { getHomePermalink, getPermalink, getBlogPermalink } from '~/utils/permalinks';

const metadata = { title: '404 — lost in space' };

const transmission = `$ cd /the-page-you-wanted
ground-control: no such route
› signal lost — this page drifted off into space
› try one of: /work  /blog  /about`;
---

<Layout metadata={metadata}>
  <section class="mx-auto flex max-w-3xl flex-col items-start px-6 py-24">
    <div class="mb-[22px] flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-spot">
      <span class="h-px w-[26px] bg-spot"></span>
      error
    </div>
    <h1 class="font-display text-[clamp(72px,16vw,160px)] font-extrabold leading-[0.86] tracking-[-0.04em] text-ink">
      404
    </h1>
    <p class="mt-5 max-w-[46ch] font-body text-xl text-ink-2">
      The page you were looking for isn&rsquo;t here. No drama — let&rsquo;s get you back to base.
    </p>

    <div class="mt-9 w-full">
      <CodeBlock code={transmission} lang="bash" title="ground-control · 404" />
    </div>

    <div class="mt-9 flex flex-wrap items-center gap-3">
      <Button href={getHomePermalink()}>← Back to base</Button>
      <Button variant="ghost" href={getPermalink('/work')}>Work</Button>
      <Button variant="ghost" href={getBlogPermalink()}>Blog</Button>
    </div>
  </section>
</Layout>
