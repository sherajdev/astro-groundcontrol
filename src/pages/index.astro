---
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';
import ComicPanel from '~/components/ui/ComicPanel.astro';
import ProjectCard from '~/components/ui/ProjectCard.astro';
import ListRow from '~/components/ui/ListRow.astro';
import CodeBlock from '~/components/ui/CodeBlock.astro';
import avatar from '~/assets/images/avatar.png';

import { getCollection } from 'astro:content';
import { findLatestPosts } from '~/utils/blog';
import { getPermalink, getBlogPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Ground Control — developer portfolio + blog',
  ignoreTitleTemplate: true,
};

// Featured work — pulled from the `work` collection.
const featured = (await getCollection('work', ({ data }) => data.featured && !data.draft))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 3);

const recentPosts = await findLatestPosts({ count: 3 });
const dottedDate = (d: Date) =>
  `${d.getFullYear()} · ${String(d.getMonth() + 1).padStart(2, '0')} · ${String(d.getDate()).padStart(2, '0')}`;

// The home page's featured code snippet. The blinking cursor is placed
// automatically by the site-wide script (PageLayout.astro) on the last terminal
// of each page; on the home page that is this block.
const heroSnippet = `// ground control — ship work, not noise
import { defineCollection, z } from "astro:content";

const work = defineCollection({
  type: "content",
  schema: z.object({
    title: z.string(),
    stack: z.array(z.string()),
    year: z.number().default(2026),
    shipped: z.boolean(),
  }),
});

export const collections = { work };`;
---

<Layout metadata={metadata}>
  <!-- HERO ─ display headline + comic panel (the one loud thing) -->
  <section class="relative overflow-hidden">
    <div
      class="gridlines absolute inset-0 opacity-50 [-webkit-mask-image:linear-gradient(to_bottom,#000,transparent_86%)] [mask-image:linear-gradient(to_bottom,#000,transparent_86%)]"
      aria-hidden="true"
    >
    </div>
    <div
      class="relative mx-auto grid max-w-6xl items-center gap-10 px-6 pb-24 pt-20 md:grid-cols-[1.35fr_0.9fr] md:gap-[54px]"
    >
      <div>
        <div
          class="gc-reveal d1 mb-[22px] flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep"
        >
          <span class="h-px w-[26px] bg-steel"></span>
          <span class="text-faint">v0.1</span> &nbsp;developer portfolio
        </div>
        <h1
          class="gc-reveal d2 font-display text-[clamp(44px,7.4vw,90px)] font-extrabold leading-[0.94] tracking-[-0.035em] text-ink"
        >
          Ground<br />Control<em class="not-italic text-steel">.</em>
        </h1>
        <p class="gc-reveal d3 mt-6 max-w-[46ch] font-body text-xl leading-relaxed text-ink-2">
          A calm, editorial dev portfolio with one comic panel, a muted steel palette, and a ghosted-Tron terminal for
          the code. Restraint everywhere — drama in exactly one place.
        </p>
        <div class="gc-reveal d4 mt-7 flex flex-wrap items-center gap-3">
          <Button href={getPermalink('/work')}>View work →</Button>
          <Button variant="ghost" href={getBlogPermalink()}>Read the blog</Button>
        </div>
      </div>

      <div class="gc-reveal d4 flex justify-center py-6 md:justify-end md:pr-2">
        <ComicPanel src={avatar.src} alt="Avatar" captionStrong="✦" caption="now shipping" />
      </div>
    </div>
  </section>

  <!-- THE TERMINAL ─ the featured code snippet; the page's last terminal, so the cursor lands here -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="mb-2 flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep">
        <span class="h-px w-[26px] bg-steel"></span>
        <span class="text-faint">01</span> &nbsp;the terminal
      </div>
      <h2 class="font-display text-[clamp(28px,4vw,46px)] font-bold leading-[1.02] tracking-[-0.02em] text-ink">
        Where the code gets to glow.
      </h2>
      <p class="mt-[18px] max-w-[62ch] font-body text-[19px] text-ink-2">
        The single dark surface in a light site &mdash; faint grid, low-glow cyan, a cursor that won&rsquo;t sit still.
        Restrained enough to read for real: a code block, not a screensaver.
      </p>

      <div class="mt-11 max-w-3xl">
        <CodeBlock
          code={heroSnippet}
          lang="ts"
          title="~/ground-control/src/content/config.ts"
          prompt="build complete — 0 errors, 12 routes"
        />
      </div>
    </div>
  </section>

  <!-- FEATURED WORK -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="mb-2 flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep">
        <span class="h-px w-[26px] bg-steel"></span>
        <span class="text-faint">02</span> &nbsp;selected work
      </div>
      <h2 class="font-display text-[clamp(28px,4vw,46px)] font-bold leading-[1.02] tracking-[-0.02em] text-ink">
        Things I&rsquo;ve shipped.
      </h2>
      <p class="mt-[18px] max-w-[62ch] font-body text-[19px] text-ink-2">
        A few projects worth a closer look. The rest live on the work page.
      </p>

      <div class="mt-11 grid gap-[18px] md:grid-cols-3">
        {
          featured.map((p) => (
            <ProjectCard
              title={p.data.title}
              href={getPermalink(`/work/${p.id}`)}
              thumbLabel={p.data.thumbLabel ?? p.data.title}
              badge={{ text: 'project', variant: 'steel' }}
              meta={[p.data.year, ...(p.data.stack ?? []).slice(0, 1)].filter(Boolean).join(' · ')}
              description={p.data.excerpt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- RECENT WRITING -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="mb-2 flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep">
        <span class="h-px w-[26px] bg-steel"></span>
        <span class="text-faint">03</span> &nbsp;recent writing
      </div>
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 class="font-display text-[clamp(28px,4vw,46px)] font-bold leading-[1.02] tracking-[-0.02em] text-ink">
          From the blog.
        </h2>
        <Button variant="link" href={getBlogPermalink()}>all posts →</Button>
      </div>

      <div class="mt-8">
        {
          recentPosts.map((post) => (
            <ListRow
              title={post.title}
              href={getPermalink(post.permalink, 'post')}
              date={`${dottedDate(post.publishDate)}${post.readingTime ? ` · ${post.readingTime} min` : ''}`}
              description={post.excerpt}
              badge={{ text: post.category?.title ?? 'post', variant: 'steel' }}
            />
          ))
        }
      </div>
    </div>
  </section>
</Layout>
