---
import Layout from '~/layouts/PageLayout.astro';
import ComicPanel from '~/components/ui/ComicPanel.astro';
import Pill from '~/components/ui/Pill.astro';
import Button from '~/components/ui/Button.astro';
import avatar from '~/assets/images/avatar.png';
import { getBlogPermalink, getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'About',
  description: 'A customizable about page for the Ground Control portfolio starter.',
};

const stack = ['Astro', 'TypeScript', 'Tailwind CSS', 'Design systems', 'Content', 'Automation'];

const principles = [
  {
    title: 'Start with the problem',
    text: 'Explain what kinds of problems you enjoy solving and why they matter to you.',
  },
  {
    title: 'Learn by building',
    text: 'Describe how experiments, shipped work, and curiosity shape your practice.',
  },
  {
    title: 'Share the process',
    text: 'Use the blog to document useful discoveries, decisions, and lessons learned.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-6 pb-24 pt-16">
    <div class="mb-[22px] flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep">
      <span class="h-px w-[26px] bg-steel"></span>
      <span class="text-faint">04</span> &nbsp;about the person behind the work
    </div>

    <h1 class="font-display text-[clamp(40px,6vw,72px)] font-extrabold leading-[0.96] tracking-[-0.03em] text-ink">
      Hi, I&rsquo;m Your Name<em class="not-italic text-steel">.</em>
    </h1>

    <div class="mt-12 grid items-start gap-14 md:grid-cols-[0.85fr_1.15fr] md:gap-16">
      <div class="flex justify-center py-4 md:justify-start md:pl-2">
        <ComicPanel src={avatar.src} alt="Placeholder artwork" caption="YOUR NAME //" captionStrong="now shipping" />
      </div>

      <div class="max-w-[58ch]">
        <div class="gc-prose">
          <p>
            This page is ready for your story. Introduce yourself, the work you care about, and the path that brought
            you here. A specific point of view is more memorable than a long list of tools.
          </p>
          <p>
            Add a short paragraph about your experience, another about what you are exploring now, and a final note
            about the kinds of projects or collaborations you welcome.
          </p>
          <p>Keep the voice personal and concrete. Replace this placeholder copy before publishing your portfolio.</p>
        </div>

        <div class="mt-9">
          <h2 class="font-display text-xl font-semibold tracking-[-0.01em] text-ink">The stack I reach for</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {stack.map((item) => <Pill>{item}</Pill>)}
          </div>
        </div>

        <div class="mt-9 rounded-lg border border-line bg-surface p-5">
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-steel-deep">Positioning line</p>
          <p class="mt-3 font-display text-2xl font-semibold leading-tight tracking-[-0.02em] text-ink">
            Write one clear sentence about the value you create and who you create it for.
          </p>
        </div>
      </div>
    </div>

    <section class="mt-24" aria-labelledby="principles-heading">
      <div class="max-w-3xl">
        <p class="font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep">Working style</p>
        <h2
          id="principles-heading"
          class="mt-3 font-display text-[clamp(32px,4vw,52px)] font-bold leading-none tracking-[-0.035em] text-ink"
        >
          How I like to build
        </h2>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {
          principles.map((item, index) => (
            <article class="rounded-lg border border-line bg-surface p-6">
              <span class="font-mono text-[12px] text-faint">0{index + 1}</span>
              <h3 class="mt-5 font-display text-2xl font-semibold tracking-[-0.02em] text-ink">{item.title}</h3>
              <p class="mt-3 font-body text-[16px] leading-relaxed text-ink-2">{item.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <div class="mt-20 flex flex-wrap gap-3 border-t border-line pt-8">
      <Button href={getPermalink('/work')}>View work →</Button>
      <Button variant="ghost" href={getBlogPermalink()}>Read the blog</Button>
    </div>
  </section>
</Layout>
