---
import Layout from '~/layouts/PageLayout.astro';
import StyleguidePalette from '~/components/StyleguidePalette.astro';

const metadata = {
  title: 'Styleguide — Ground Control',
};
---

<Layout metadata={metadata}>
  <section class="max-w-5xl mx-auto px-6 py-12">
    <p class="font-mono text-sm uppercase tracking-widest text-spot">foundation</p>
    <h1 class="mt-3 font-display font-extrabold text-4xl md:text-5xl tracking-tight">Styleguide</h1>
    <p class="mt-3 max-w-[60ch] font-body text-lg text-muted">
      The Ground Control tokens, type scale, and textures. Use the header toggle to flip the whole page, or compare the
      two framed panels below side by side.
    </p>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      <div>
        <p class="mb-2 font-mono text-xs uppercase tracking-widest text-muted">light</p>
        <div class="rounded-lg border border-line overflow-hidden">
          <StyleguidePalette />
        </div>
      </div>
      <div class="dark">
        <p class="mb-2 font-mono text-xs uppercase tracking-widest text-muted">dark</p>
        <div class="rounded-lg border border-line overflow-hidden">
          <StyleguidePalette />
        </div>
      </div>
    </div>
  </section>
</Layout>
