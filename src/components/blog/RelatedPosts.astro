---
import { APP_BLOG } from 'astrowind:config';

import { getRelatedPosts } from '~/utils/blog';
import ListRow from '~/components/ui/ListRow.astro';
import { getPermalink } from '~/utils/permalinks';
import { getDottedDate } from '~/utils/utils';
import type { Post } from '~/types';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const relatedPosts = post.tags ? await getRelatedPosts(post, 3) : [];
---

{
  APP_BLOG.isRelatedPostsEnabled && relatedPosts.length > 0 && (
    <section class="mx-auto max-w-3xl px-6 pb-20">
      <div class="border-t border-line pt-10">
        <div class="mb-6 flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-steel-deep">
          <span class="h-px w-[26px] bg-steel" />
          related
        </div>
        <div>
          {relatedPosts.map((p) => (
            <ListRow
              title={p.title}
              href={getPermalink(p.permalink, 'post')}
              date={getDottedDate(p.publishDate, p.readingTime)}
              description={p.excerpt}
              badge={{ text: p.category?.title ?? 'post', variant: 'steel' }}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
