---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
}

const { secondaryLinks = [], socialLinks = [], footNote = '' } = Astro.props;
---

<footer class="not-prose border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div
      class="flex flex-wrap items-center justify-between gap-x-8 gap-y-5 font-mono text-xs tracking-[0.04em] text-muted"
    >
      <!-- Left: brand + secondary links -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <a class="font-semibold uppercase text-ink transition-colors hover:text-ink" href={getHomePermalink()}>
          {SITE?.name}
        </a>
        {
          secondaryLinks.map(({ text, href }) => (
            <a class="transition-colors hover:text-ink" href={href} set:html={text} />
          ))
        }
      </div>

      <!-- Right: social (RSS lives here) + the one spot -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <ul class="flex items-center gap-3">
          {
            socialLinks.map(({ ariaLabel, href, icon }) => (
              <li>
                <a
                  class="inline-flex items-center text-muted transition-colors hover:text-ink"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="h-4 w-4" />}
                </a>
              </li>
            ))
          }
        </ul>
        {
          footNote && (
            <span>
              <span class="text-spot">✦</span> <Fragment set:html={footNote} />
            </span>
          )
        }
      </div>
    </div>
  </div>
</footer>
