---
// Mono badge. Variants mirror the design: default (surface), solid (ink),
// steel, and ghost (transparent, keeps the hairline border).
export interface Props {
  variant?: 'default' | 'solid' | 'steel' | 'ghost';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants: Record<string, string> = {
  default: 'bg-surface text-ink-2 border-line-strong',
  solid: 'bg-ink text-bg border-ink',
  steel: 'bg-steel text-white border-steel',
  ghost: 'bg-transparent text-ink-2 border-line-strong',
};
---

<span
  class:list={[
    'inline-flex items-center whitespace-nowrap rounded-full border px-[11px] py-[5px] font-mono text-[11.5px] tracking-[0.05em]',
    variants[variant],
    className,
  ]}
>
  <slot />
</span>
